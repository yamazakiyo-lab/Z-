# ============================================================
# .env.example — このファイルをコピーして .env にリネームし、
# 実際の値を入力してください。
# .env は GitHub にコミットしないこと（.gitignore 設定済み）。
# ============================================================

# ── Azure AI Search ──────────────────────────────────────────
# Azure ポータル > AI Search リソース > 概要 > URL
AZURE_SEARCH_ENDPOINT=https://your-search-name.search.windows.net

# Azure ポータル > AI Search リソース > 設定 > キー > 管理者キー
AZURE_SEARCH_API_KEY=your-search-admin-key

# インデックス名（デフォルト: photo-index）
# AZURE_SEARCH_INDEX_NAME=photo-index

# ── スキャン対象フォルダ（デフォルト値のまま使う場合は不要） ──
# TARGET_91_ROOT=Z:\takachiho\2to9_業務別フォルダ\91_工番別実績写真・動画
# TARGET_271_ROOT=Z:\takachiho\2to9_業務別フォルダ\27_サービス・出張工事\271_修理工事指令書

# ── Azure Blob Storage（TSEG FMP SEARCH 閲覧URL・AzCopy同期用） ─
# ストレージアカウント > コンテナ右クリック > SASの生成
# 権限: 読み取り・書き込み・削除・一覧表示、有効期限を長め（1〜2年）に設定
#
# 91_工番別実績写真・動画 の Blob ベース URL とSASトークン
AZURE_BLOB_BASE_URL=https://tsegphotos.blob.core.windows.net/photos
AZURE_BLOB_SAS_TOKEN=sv=2024-xx-xx&ss=b&srt=co&sp=rwdlacupiytfx&...（SASトークン文字列）
#
# 271_修理工事指令書 の Blob ベース URL
# コンテナ名 shirei-pdf を Azure Portal で作成してから設定する
AZURE_BLOB_271_BASE_URL=https://tsegphotos.blob.core.windows.net/shirei-pdf
# 271専用SASトークン（photos と同じアカウントレベルSASなら省略可、共通トークンが使われる）
# AZURE_BLOB_271_SAS_TOKEN=sv=...

# ── バッチサイズ（通常は変更不要） ──────────────────────────
# UPLOAD_BATCH_SIZE=500

# ── Azure OpenAI（画像説明文 GPT-4o Vision 用） ───────────────
# Azure ポータル > Azure OpenAI リソース > 概要 > エンドポイント
AZURE_OPENAI_ENDPOINT=https://your-openai-name.openai.azure.com/

# Azure ポータル > Azure OpenAI リソース > キーとエンドポイント > キー1
AZURE_OPENAI_API_KEY=your-openai-api-key

# Azure OpenAI Studio でデプロイしたモデルの「デプロイ名」（リソース名ではない）
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o

# API バージョン（通常は変更不要）
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── LINE WORKS Bot 受信サーバー ───────────────────────────────
# Developer Console > Bot > Bot Secret
LINEWORKS_BOT_SECRET=your-bot-secret

# Developer Console > ClientApp > Client ID
LINEWORKS_CLIENT_ID=your-client-id

# Developer Console > ClientApp > Client Secret
LINEWORKS_CLIENT_SECRET=your-client-secret

# Developer Console > Service Account (メールアドレス形式)
LINEWORKS_SERVICE_ACCOUNT=your-service-account@example.com

# Service Account 用 Private Key ファイルのパス
LINEWORKS_PRIVATE_KEY_PATH=C:\lineworks_bot_test\private_key.pem

# Developer Console > Bot > Bot ID (数字)
LINEWORKS_BOT_ID=your-bot-id

# スコープ（変更不要）
LINEWORKS_SCOPE=bot.message

# ── LINE WORKS Bot ログ保存先 ────────────────────────────────
# Callbackで受信したJSONの保存フォルダ
LW_LOG_DIR=C:\lineworks_bot_test\logs

# ── LINE WORKS LWExtraction 保存先（Step4以降） ───────────────
# LW_EXTRACTION_ROOT=Z:\takachiho\2to9_業務別フォルダ\91_工番別実績写真・動画\LWExtraction
